{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "*secrets*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "bash": {
      "*": "ask",
    },
    "skill": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "external_directory": "ask",
    "doom_loop": "ask",
  },
}
