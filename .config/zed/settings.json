{
  "modeline_lines": 0,
  "format_on_save": "off",
  "autosave": "on_focus_change",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },
  "agent": {
    "dock": "left",
    "enable_feedback": false,
    "profiles": {},
    "use_modifier_to_send": true,
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gpt-5.6-luna",
    },
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
  },

  "relative_line_numbers": "enabled",
  "cursor_blink": false,
  "soft_wrap": "editor_width",

  "wrap_guides": [80, 120],
  "max_tabs": 1,
  "tab_bar": {
    "show": false,
  },
  "scrollbar": {
    "show": "never",
  },

  "theme": {
    "mode": "system",
    "light": "One Dark",
    "dark": "One Dark",
  },

  "ui_font_size": 16,
  "buffer_font_size": 13,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_line_height": {
    "custom": 1.8,
  },

  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
}
